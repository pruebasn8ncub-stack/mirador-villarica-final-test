      "parameters": {
        "jsCode": "// Branching determinista sin If node: marca cada item como send o skip.\nconst d = $json;\nif (d.skip_send === true) {\n  return [{ json: { ...d, _action: 'skip' } }];\n}\nreturn [{ json: { ...d, _action: 'send' } }];"
      },
