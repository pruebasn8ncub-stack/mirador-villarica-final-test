    {
      "parameters": {
        "jsCode": "const d = $json;\n\nconst isBrokerRequest = d.broker_request === true || !!d.motivo;\n\nconst texto = [\n  '🔔 *SOLICITUD DE CONTACTO — MIRADOR DE VILLARRICA*',\n  '',\n  `👤 *Nombre:* ${d.nombre || '—'}`,\n  `📧 *Correo:* ${d.email || '—'}`,\n  `📱 *WhatsApp:* ${d.whatsapp || '—'}`,\n  '',\n].join('\\n');\n\nconst hasLeadId = !!d.lead_id;\n\nreturn [{ json: {\n  text: texto,\n  number: '56992533044',\n  lead_id: d.lead_id,\n  session_id: d.session_id,\n  skip_send: d.skip_send === true || !hasLeadId,\n  is_broker_request: isBrokerRequest,\n} }];"
      },
