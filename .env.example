# ============================================
# Mirador Villarrica Chatbot — env example
# ============================================
# Copy to .env.local for development and set real values in Vercel dashboard.

# --- Frontend (Next.js) ---
# Webhook del flujo principal n8n
N8N_WEBHOOK_URL=https://n8n.automind.cl/webhook/mirador-chat
N8N_WEBHOOK_TOKEN=change-me

# --- Backend (n8n env, NO en Vercel) ---
